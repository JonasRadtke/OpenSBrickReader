<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/read"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.openSBrickReader.ReadActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Titel -->
            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Read and Save NFC Data"
                android:textAlignment="center"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Save Button -->
            <Button
                android:id="@+id/buttonSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Save Binary (to Download folder)" />

            <!-- UID -->
            <TextView
                android:id="@+id/tvUID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UID: ??"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Config -->
            <TextView
                android:id="@+id/tvConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Config: ??"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <!-- Data Label -->
            <TextView
                android:id="@+id/tvDataLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data:"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- NFC Data -->
            <TextView
                android:id="@+id/tvBlocks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for NFC tag..."
                android:textSize="14sp"
                android:typeface="monospace"
                android:background="#EEEEEE"
                android:padding="12dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>