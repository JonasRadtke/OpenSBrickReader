<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/read"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.openSBrickReader.ReadActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/read1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speichern" />

            <TextView
                android:id="@+id/tvUID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:text="UID wird hier angezeigt"
                android:textSize="20sp"
                app:layout_constraintTop_toTopOf="parent"
                tools:layout_editor_absoluteX="102dp" />

            <TextView
                android:id="@+id/tvConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Config wird hier angezeigt"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@+id/tvUID"
                tools:layout_editor_absoluteX="113dp" />

            <TextView
                android:id="@+id/tvBlocks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Config wird hier angezeigt"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/tvConfig"
                tools:layout_editor_absoluteX="39dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>